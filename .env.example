# ==========================================
# NEXUS WEB HUB - ENVIRONMENT CONFIGURATION
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Turso Database Configuration
# Get your credentials at: https://turso.tech
# 1. Create database: turso db create nexus-web-hub
# 2. Get URL: turso db show nexus-web-hub --url
# 3. Create token: turso db tokens create nexus-web-hub
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Database Reset (USE WITH CAUTION!)
# Set to 'true' to drop all tables and recreate schema
# Useful for fixing schema issues or fresh start
# REMEMBER TO SET BACK TO 'false' AFTER ONE DEPLOY!
FORCE_RESET_DB=false

# Optional: Rate Limiting (requests per 15 minutes)
# RATE_LIMIT_MAX=100