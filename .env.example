# Database (Turso)
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your_turso_auth_token_here

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters

# Admin Credentials
ADMIN_EMAIL=admin@nexusstudio.com
ADMIN_PASSWORD=YourSecureAdminPassword123!

# Admin API Key (for monitoring endpoints)
ADMIN_KEY=your_admin_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=production

# Rate Limiting (optional, defaults shown)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Reset Database (DANGER: set to true to reset DB on startup)
RESET_DB=false

# Application URL (for SEO)
APP_URL=https://nexuswebhub.com